{
  "version": 2,
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "env": {
    "SUPABASE_URL": {
      "description": "Supabase project URL"
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase service role key (keep secret)"
    },
    "VITE_SUPABASE_URL": {
      "description": "Supabase URL for frontend"
    },
    "VITE_SUPABASE_ANON_KEY": {
      "description": "Supabase anonymous key for frontend"
    },
    "JWT_SECRET": {
      "description": "JWT secret for session management"
    },
    "VITE_APP_ID": {
      "description": "Application ID"
    },
    "VITE_APP_TITLE": {
      "description": "Application title"
    },
    "VITE_APP_LOGO": {
      "description": "Application logo URL"
    },
    "VITE_OAUTH_PORTAL_URL": {
      "description": "OAuth portal URL"
    },
    "OAUTH_SERVER_URL": {
      "description": "OAuth server URL"
    },
    "BUILT_IN_FORGE_API_URL": {
      "description": "Built-in Forge API URL"
    },
    "BUILT_IN_FORGE_API_KEY": {
      "description": "Built-in Forge API key"
    },
    "VITE_FRONTEND_FORGE_API_URL": {
      "description": "Frontend Forge API URL"
    },
    "VITE_FRONTEND_FORGE_API_KEY": {
      "description": "Frontend Forge API key"
    }
  },
  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/_core/index.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/$1"
    }
  ]
}
